# Django
DJANGO_SECRET_KEY=change-this-to-a-long-random-secret
DEBUG=False
PORT=8001
ALLOWED_HOSTS=localhost,127.0.0.1,your-pakistan-server-domain.com

# API key your ERP must send in the X-API-Key header
BRIDGE_API_KEY=your-secure-bridge-api-key

# FBR settings (get token from e.fbr.gov.pk after registration)
FBR_ENVIRONMENT=sandbox
FBR_SECURITY_TOKEN=your-fbr-security-token-from-portal

# Optional overrides
# FBR_SANDBOX_BASE_URL=https://esp.fbr.gov.pk:8244
# FBR_SANDBOX_SSL_BASE_URL=https://gw.fbr.gov.pk
# FBR_PRODUCTION_BASE_URL=https://gw.fbr.gov.pk/pdi/v1/api
# FBR_REQUEST_TIMEOUT=60
# FBR_VERIFY_SSL=True
# LOG_LEVEL=INFO
